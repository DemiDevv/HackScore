POSTGRES_DB=hackscore
POSTGRES_USER=hackscore
POSTGRES_PASSWORD=hackscore
POSTGRES_PORT=5432

DATABASE_URL=postgresql+asyncpg://hackscore:hackscore@postgres:5432/hackscore
REDIS_URL=redis://redis:6379/0
SECRET_KEY=replace-with-a-long-random-secret
UPLOAD_DIR=/app/uploads
ENVIRONMENT=development
HACKSCORE_RUN_MIGRATIONS=true
HACKSCORE_AUTO_SEED=true

BACKEND_PORT=8000
FRONTEND_PORT=5173
REDIS_PORT=6379
